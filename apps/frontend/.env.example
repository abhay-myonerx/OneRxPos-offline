
NEXT_PUBLIC_TEST_MODE=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_CODECANYON_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Test-mode quick-login emails (dev only, gated by NEXT_PUBLIC_TEST_MODE).
# Passwords are intentionally NOT stored here — never expose credentials via
# NEXT_PUBLIC_* variables, as they would be shipped in the public browser
# bundle. Test passwords are entered manually and kept in project docs.
NEXT_PUBLIC_TEST_ADMIN_EMAIL=
NEXT_PUBLIC_TEST_MANAGER_EMAIL=
NEXT_PUBLIC_TEST_CASHIER_EMAIL=
NEXT_PUBLIC_TEST_HR_EMAIL=
NEXT_PUBLIC_TEST_EMPLOYEE_EMAIL=

# Vite/SPA shell — mirrors the NEXT_PUBLIC_* values above for the dual-shell build.
VITE_API_URL=http://localhost:4001/api/v1
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ------------------------------------------------------------
# RXADMIN CLOUD AUTHENTICATION
# ------------------------------------------------------------
#
# Public RXAdmin API origin.
#
# Used only for:
# - initial cloud login
# - registration
# - OTP
# - MFA
# - pharmacy selection
# - account validation
# - device approval
# - initial activation
#
# NEVER place private secrets in VITE_* variables.

VITE_RXADMIN_API_URL=
VITE_RXADMIN_PLATFORM=
VITE_RXADMIN_CLIENT_TYPE=