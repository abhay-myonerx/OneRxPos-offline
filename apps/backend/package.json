{
  "name": "rx-pos-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run build:shared && tsx watch src/server.ts",
    "build:shared": "npm --prefix ../../packages/shared run build",
    "prebuild": "npm run build:shared && npm run db:generate:sqlite",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "postbuild": "node scripts/copy-prisma-engines.mjs",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:ddl:sqlite": "tsx -r tsconfig-paths/register scripts/generate-sqlite-ddl.ts",
    "db:push:sqlite": "tsx -r tsconfig-paths/register scripts/push-sqlite-schema.ts",
    "db:seed:sqlite": "tsx -r tsconfig-paths/register scripts/seed-super-admin-sqlite.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:demo": "npx tsx prisma/seed-demo.ts",
    "db:seed:super-admin": "tsx -r tsconfig-paths/register scripts/seed-super-admin.ts",
    "db:images": "tsx -r tsconfig-paths/register scripts/update-product-images.ts",
    "import:dpd": "tsx -r tsconfig-paths/register scripts/import-dpd.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "pretest": "npm run build:shared",
    "test": "vitest run",
    "test:watch": "npm run build:shared && vitest",
    "lint": "eslint src/ --ext .ts",
    "pretypecheck": "npm run build:shared",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "6.19.3",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^6.19.3",
    "@sendgrid/mail": "^8.1.6",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "file:./src/local/sqlcipher-shim",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "bullmq": "^5.71.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-hid": "^3.3.0",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rx-pos-shared": "file:../rx-pos-shared",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "better-sqlite3": "file:./src/local/sqlcipher-shim"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.9.4",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.2"
  }
}
