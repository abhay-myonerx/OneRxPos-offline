# ─────────────────────────────────────────────────────────────────────────────
# RX POS v2 — backend environment template
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Validation lives in `src/config/index.ts` (Zod). Any missing/invalid value
# will fail server startup with a descriptive error.
#
# Values shown here are LOCAL-DEV PLACEHOLDERS, not secrets. Production
# values MUST be set in the deployment platform's secret manager.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/posvelo?schema=public

# Store-node data backend switch — "postgres" (default) uses DATABASE_URL
# above; "sqlite" resolves a keyed SQLCipher client instead and DATABASE_URL
# is not required. See src/config/database.ts.
DATA_BACKEND=postgres

# Redis (sessions, rate-limit, BullMQ)
REDIS_URL=redis://localhost:6379

# Demo / sandbox mode flag — read by demoGuard middleware
DEMO_MODE=false

# JWT — generate strong secrets per environment (≥32 chars enforced).
# Local dev placeholders only. NEVER reuse these in production.
JWT_ACCESS_SECRET=change-me-locally-with-a-random-64-char-string-aaaaaaaaaaaaa
JWT_REFRESH_SECRET=change-me-locally-with-a-random-64-char-string-bbbbbbbbbbbb
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Secret rotation (Phase 0.8): optional previous keys for zero-downtime rotation.
# Leave empty except during a rotation overlap window. See docs/ops/secrets-and-rotation.md
JWT_ACCESS_SECRET_PREVIOUS=
JWT_REFRESH_SECRET_PREVIOUS=

# Password hashing (argon2 is primary; this is a legacy bcrypt knob)
BCRYPT_ROUNDS=12

# Rate limiting (global default; per-route limiters may override)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000


MASTER_ENCRYPTION_KEY=

# Store-node local encrypted DB (SQLCipher via better-sqlite3-multiple-ciphers).
# LOCAL_DB_PATH is also the path the DATA_BACKEND=sqlite Prisma client resolver
# uses at runtime (src/config/database.ts) — CWD-relative, distinct from
# SQLITE_DATABASE_URL below which Prisma's own schema loader resolves relative
# to prisma/.
LOCAL_DB_PATH=./data/store-node.db
LOCAL_DB_MASTER_KEY=

# Store-node SQLite Prisma datasource (prisma/schema.sqlite.prisma). File path
# is resolved relative to the schema file (prisma/), so this points at the
# same physical file as LOCAL_DB_PATH above.
SQLITE_DATABASE_URL=file:../data/store-node.db

# First-run bootstrap for the store-node encrypted DB, once DATA_BACKEND=sqlite
# and LOCAL_DB_MASTER_KEY are set:
#   npm run db:push:sqlite   # creates the schema in the file at LOCAL_DB_PATH
#   npm run db:seed:sqlite   # inserts one SUPER_ADMIN user (idempotent)
# db:seed:sqlite reuses SUPER_ADMIN_EMAIL/SUPER_ADMIN_PASSWORD below if set,
# else falls back to dev placeholders (admin@storenode.local / ChangeMe123!StoreNode)
# — see scripts/seed-super-admin-sqlite.ts.

# Store-node <-> cloud sync
SYNC_DEVICE_ID=dev-device-0001
# REQUIRED — no default; generate a strong secret per environment (≥32 chars enforced).
SYNC_TOKEN_SECRET=
SYNC_TOKEN_SECRET_PREVIOUS=
CLOUD_SYNC_URL=http://localhost:4001/api/v2/sync

# Phase 0.5 licensing (store-node)
LICENSE_TOKEN_SECRET=change-me-to-a-32+-char-random-secret-000000
LICENSE_TOKEN_SECRET_PREVIOUS=
LICENSE_KEY=
CLOUD_LICENSE_URL=http://localhost:4001/api/v2/license
LICENSE_DEGRADE_DAYS=7
LICENSE_LOCKOUT_DAYS=30
# DEVICE_FINGERPRINT=   # optional override; else computed from hardware

# Phase 1.1 POS auth (PIN & override security)
PIN_PEPPER_SECRET=change-me-to-a-32+-char-random-secret-111111
PIN_PEPPER_SECRET_PREVIOUS=
POS_OVERRIDE_SECRET=change-me-to-a-32+-char-random-secret-222222
POS_OVERRIDE_SECRET_PREVIOUS=
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15

# Desktop packaging (rx-pos-desktop): RENDERER_ENCRYPTION_KEY (64 hex), WIN_CSC_LINK (.pfx path/URL) + WIN_CSC_KEY_PASSWORD for EV signing

# Super-admin / setup bootstrap (used by scripts/seed-super-admin.ts and
# the setup module). Leave blank in committed example.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SETUP_ACCESS_CODE=
