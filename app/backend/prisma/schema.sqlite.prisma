// ============================================================================
// HRM — EMPLOYEE (Phase 6, ERD §10.3 — basic fields only; sensitive fields
// and salary/contracts/documents land in follow-up prompts. See OPEN_ITEMS
// OI-023..OI-027.)
// ============================================================================

model Employee {
  id                     String           @id @default(uuid())
  tenantId               String           @map("tenant_id")
  userId                 String?          @unique @map("user_id")
  employeeCode           String           @map("employee_code")
  firstName              String           @map("first_name")
  lastName               String           @map("last_name")
  middleName             String?          @map("middle_name")
  email                  String?
  phone                  String?
  alternatePhone         String?          @map("alternate_phone")
  dateOfBirth            DateTime?        @map("date_of_birth")
  gender                 String?
  maritalStatus          String?          @map("marital_status")
  address                String?
  city                   String?
  state                  String?
  postalCode             String?          @map("postal_code")
  country                String?
  emergencyContact       Json?            @map("emergency_contact")
  photo                  String?
  departmentId           String           @map("department_id")
  designationId          String           @map("designation_id")
  storeId                String?          @map("store_id")
  reportsToId            String?          @map("reports_to_id")
  employmentStatus       String @default("ACTIVE") @map("employment_status")
  employmentType         String   @default("FULL_TIME") @map("employment_type")
  employmentStartDate    DateTime         @map("employment_start_date")
  confirmationDate       DateTime?        @map("confirmation_date")
  employmentEndDate      DateTime?        @map("employment_end_date")
  separationReason       String?          @map("separation_reason")
  separationNotes        String?          @map("separation_notes")
  // Set true by terminate(); the next processed PayrollRun includes the
  // employee for a prorated final-settlement payslip and the flag is
  // cleared when that run is approved (payslips FINALIZED). OI-040.
  finalSettlementPending Boolean          @default(false) @map("final_settlement_pending")
  noticePeriodDays       Int?             @map("notice_period_days")
  notes                  String?
  // ── Sensitive PII (Phase 20a / OI-023) ────────────────────────
  // Per Schema Conventions §11 — encrypted at rest via the
  // per-tenant HKDF/AES-GCM util in `src/lib/encryption.ts`.
  // Plaintext never leaves the service layer; the API surface
  // returns `{ hasNationalId: true, last4: "1234" }`-style
  // previews unless the actor holds `hr.employees.read.sensitive`.
  nationalIdEnc          String?          @map("national_id_enc")
  passportNumberEnc      String?          @map("passport_number_enc")
  taxIdEnc               String?          @map("tax_id_enc")
  bankDetailsEnc         String?          @map("bank_details_enc")
  isActive               Boolean          @default(true) @map("is_active")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  department  Department  @relation(fields: [departmentId], references: [id])
  designation Designation @relation(fields: [designationId], references: [id])
  reportsTo   Employee?   @relation("EmployeeManager", fields: [reportsToId], references: [id])
  reports     Employee[]  @relation("EmployeeManager")

  attendanceRecords     AttendanceRecord[]
  attendanceCorrections AttendanceCorrection[]
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]
  salaries              EmployeeSalary[]
  payslips              Payslip[]
  advances              SalaryAdvance[]
  contracts             EmploymentContract[]
  documents             EmployeeDocument[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, designationId])
  @@index([tenantId, employmentStatus])
  @@index([tenantId, reportsToId])
  @@index([tenantId, isActive])
  @@map("employees")
}

// ============================================================================
// HRM — EMPLOYMENT CONTRACTS (Phase 20d / OI-025)
// ============================================================================
//
// Append-only historical record of every contract cycle (initial
// hire, promotion, transfer, role/department change, contract
// renewal). Editing past contracts is disallowed at the application
// layer — corrections happen by superseding with a new row.

model EmploymentContract {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  employeeId        String    @map("employee_id")
  // What this contract cycle holds — denormalised so a contract
  // remains accurate even if the live employee row is updated.
  contractNumber    String?   @map("contract_number")
  title             String
  employmentType    String    @map("employment_type")
  departmentId      String?   @map("department_id")
  designationId     String?   @map("designation_id")
  storeId           String?   @map("store_id")
  reportsToId       String?   @map("reports_to_id")
  salaryStructureId String?   @map("salary_structure_id")
  // Effective window. End date null means "ongoing".
  effectiveFrom     DateTime  @map("effective_from")
  effectiveTo       DateTime? @map("effective_to")
  // PDF / signed-contract document URL (Cloudinary or other).
  documentUrl       String?   @map("document_url")
  // Notes are free-form HR commentary; redacted in audit.
  notes             String?
  // Provenance — supersedes the previous contract in the chain.
  supersedesId      String?   @unique @map("supersedes_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  employee     Employee            @relation(fields: [employeeId], references: [id])
  supersedes   EmploymentContract? @relation("ContractChain", fields: [supersedesId], references: [id])
  supersededBy EmploymentContract? @relation("ContractChain")

  @@index([tenantId, employeeId])
  @@index([tenantId, employeeId, effectiveFrom])
  @@map("employment_contracts")
}

// ============================================================================
// HRM — EMPLOYEE DOCUMENTS (Phase 20d / OI-025)
// ============================================================================
//
// File metadata + URL only — the actual file lives in the
// configured object store (Cloudinary in v2.0; pluggable). Backend
// validates URL shape only and does NOT proxy downloads — clients
// authorize the URL via signed Cloudinary access.

model EmployeeDocument {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  employeeId     String    @map("employee_id")
  documentType   String    @map("document_type")
  fileName       String    @map("file_name")
  fileUrl        String    @map("file_url")
  mimeType       String?   @map("mime_type")
  sizeBytes      Int?      @map("size_bytes")
  // Optional expiry — drives visa-renewal / contract-renewal alerts.
  expiresAt      DateTime? @map("expires_at")
  // Confidential docs (e.g. medical) are hidden from ESS /me/documents.
  isConfidential Boolean   @default(false) @map("is_confidential")
  uploadedBy     String?   @map("uploaded_by")
  notes          String?
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, employeeId, documentType])
  @@index([tenantId, expiresAt])
  @@map("employee_documents")
}

// ============================================================================
// MIGRATION AUDIT (v1 → v2)
// ============================================================================
//
// Append-only audit log of every v1→v2 migration / backfill operation.
// Lives independently of the main HRM dependency chain. This is the FIRST
// table created in the v2 series so subsequent backfills can write rows
// here. `tenantId` is nullable for platform-level operations.
//
// Per PRISMA_SCHEMA_CHANGE_PLAN.md §2.15.

model MigrationAuditV1ToV2 {
  id           String    @id @default(uuid())
  migratedAt   DateTime  @default(now()) @map("migrated_at")
  phase        Int
  tenantId     String?   @map("tenant_id")
  operation    String
  sourceTable  String?   @map("source_table")
  sourceRowId  String?   @map("source_row_id")
  targetTable  String?   @map("target_table")
  targetRowId  String?   @map("target_row_id")
  beforeValue  Json?     @map("before_value")
  afterValue   Json?     @map("after_value")
  reversible   Boolean   @default(true)
  actorUserId  String?   @map("actor_user_id")
  status       String    @default("APPLIED")
  rolledBackAt DateTime? @map("rolled_back_at")

  @@index([tenantId, phase])
  @@index([phase, migratedAt])
  @@index([sourceTable, sourceRowId])
  @@map("migration_audit_v1_to_v2")
}

// ============================================================================
// HRM — ATTENDANCE (Phase 7, deep-dives/2.hrm-attendance.md)
// ============================================================================
//
// Event-log model (§3): AttendanceRecord is an immutable, append-only log of
// individual punch events. "Was X present on date Y?" is a DERIVED query,
// not a column read — see src/modules/attendance/attendance.derivation.ts.
//
// MVP scope: punch core + correction workflow. Deferred to follow-ups:
// biometric devices/enrollment (OI-028), geofence/IP/QR enforcement
// (OI-029), Store geo/IP/method columns (OI-030), socket real-time board
// (OI-031), Redis derivation cache (OI-032), shift-aware derivation
// (waits on Phase 8 shifts module), holiday/leave-aware derivation
// (waits on the leave module).

model AttendanceRecord {
  id               String  @id @default(uuid())
  tenantId         String  @map("tenant_id")
  employeeId       String  @map("employee_id")
  storeId          String? @map("store_id")
  scheduledShiftId String? @map("scheduled_shift_id")

  eventType  String   @map("event_type")
  occurredAt DateTime         @map("occurred_at")
  method     String

  geoLat         Decimal? @map("geo_lat")
  geoLng         Decimal? @map("geo_lng")
  geoAccuracyM   Int?     @map("geo_accuracy_m")
  ipAddress      String?  @map("ip_address")
  deviceId       String?  @map("device_id")
  biometricRefId String?  @map("biometric_ref_id")
  photoUrl       String?  @map("photo_url")

  isRegularized Boolean @default(false) @map("is_regularized")
  correctionId  String? @unique @map("correction_id")
  notes         String?

  createdAt       DateTime @default(now()) @map("created_at")
  createdByUserId String?  @map("created_by_user_id")

  employee   Employee              @relation(fields: [employeeId], references: [id])
  correction AttendanceCorrection? @relation("CorrectionResult", fields: [correctionId], references: [id])

  @@index([tenantId, employeeId, occurredAt])
  @@index([tenantId, storeId, occurredAt])
  @@index([tenantId, scheduledShiftId])
  @@map("attendance_records")
}

model AttendanceCorrection {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  employeeId String @map("employee_id")

  requestedDate DateTime       @map("requested_date")
  eventType     String @map("event_type")
  requestedTime DateTime       @map("requested_time")
  reason        String
  evidenceUrl   String?        @map("evidence_url")

  status             String @default("PENDING")
  managerUserId      String?                    @map("manager_user_id")
  managerRespondedAt DateTime?                  @map("manager_responded_at")
  managerNotes       String?                    @map("manager_notes")
  resultingRecordId  String?                    @map("resulting_record_id")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdByUserId String?  @map("created_by_user_id")

  employee        Employee          @relation(fields: [employeeId], references: [id])
  resultingRecord AttendanceRecord? @relation("CorrectionResult")

  @@index([tenantId, employeeId, requestedDate])
  @@index([tenantId, status])
  @@map("attendance_corrections")
}

// ============================================================================
// HRM — SHIFTS & SCHEDULING (Phase 8, deep-dives/3.hrm-shifts.md)
// ============================================================================
//
// `WorkShift` — a reusable template (Morning 09:00–17:00 etc.). Tenant-scoped.
// `ShiftSchedule` — a per-employee-per-day rostered instance that SNAPSHOTS
//   the template at create time. Editing the WorkShift later never rewrites
//   historic schedules (immutability principle, deep-dive §3.2).
// `ShiftSwapRequest` — peer-accept → manager-approve workflow.
//
// HARD RULE: this is NOT CashierShift. CashierShift is the cash-drawer
// session model (§4) and stays untouched. Employee back-refs are deliberately
// omitted — this module references employees by id and uses the shared
// helpers from attendance for "team" scope (§2 dependency contract).

model WorkShift {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  storeId              String?  @map("store_id")
  name                 String
  code                 String
  startTime            String   @map("start_time")
  endTime              String   @map("end_time")
  breakMinutes         Int      @default(0) @map("break_minutes")
  graceMinutes         Int      @default(0) @map("grace_minutes")
  isNightShift         Boolean  @default(false) @map("is_night_shift")
  nightDifferentialPct Decimal? @map("night_differential_pct")
  color                String?
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  schedules ShiftSchedule[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, storeId])
  @@index([tenantId, isActive])
  @@map("work_shifts")
}

model ShiftSchedule {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  employeeId          String              @map("employee_id")
  workShiftId         String?             @map("work_shift_id")
  storeId             String?             @map("store_id")
  scheduledDate       DateTime            @map("scheduled_date")
  plannedStart        String?             @map("planned_start")
  plannedEnd          String?             @map("planned_end")
  plannedBreakMinutes Int                 @default(0) @map("planned_break_minutes")
  plannedGraceMinutes Int                 @default(0) @map("planned_grace_minutes")
  isOffDay            Boolean             @default(false) @map("is_off_day")
  status              String @default("SCHEDULED")
  notes               String?
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  workShift WorkShift? @relation(fields: [workShiftId], references: [id])

  @@unique([tenantId, employeeId, scheduledDate])
  @@index([tenantId, scheduledDate])
  @@index([tenantId, employeeId, scheduledDate])
  @@index([tenantId, storeId, scheduledDate])
  @@index([tenantId, status])
  @@map("shift_schedules")
}

model ShiftSwapRequest {
  id                    String          @id @default(uuid())
  tenantId              String          @map("tenant_id")
  requesterEmployeeId   String          @map("requester_employee_id")
  requesterScheduleId   String          @map("requester_schedule_id")
  counterpartEmployeeId String          @map("counterpart_employee_id")
  counterpartScheduleId String?         @map("counterpart_schedule_id")
  reason                String?
  status                String @default("PENDING_PEER")
  peerRespondedAt       DateTime?       @map("peer_responded_at")
  managerUserId         String?         @map("manager_user_id")
  managerRespondedAt    DateTime?       @map("manager_responded_at")
  decisionNotes         String?         @map("decision_notes")
  expiresAt             DateTime        @map("expires_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@index([tenantId, requesterEmployeeId])
  @@index([tenantId, counterpartEmployeeId])
  @@index([tenantId, status])
  @@index([tenantId, requesterScheduleId])
  @@map("shift_swap_requests")
}

// ============================================================================
// HRM — LEAVE (Phase 9, deep-dives/4.hrm-leave.md)
// ============================================================================
//
// `LeaveType`    — tenant-scoped leave category (Annual, Casual, Sick, LWP…).
// `LeavePolicy`  — entitlement/accrual rule per type, optionally per
//                  designation level.
// `LeaveBalance` — per employee × type × cycle year tracking. `availableDays`
//                  is DERIVED (entitled + carried - used - pending) — never
//                  stored. Row-locked inside every balance mutation transaction.
// `LeaveRequest` — the mutable workflow row; reserve-on-request /
//                  deduct-on-approve / release-on-reject / refund-on-cancel.
// `Holiday`      — tenant-scoped holiday calendar; optionally store-scoped.
//
// Published frozen contracts consumed by attendance & payroll:
//   isOnApprovedLeave(ctx, employeeId, localDate)
//   getPaidUnpaidLeaveDays(ctx, employeeId, periodStart, periodEnd)

model LeaveType {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  name               String
  code               String
  isPaid             Boolean  @default(true) @map("is_paid")
  isBalanceTracked   Boolean  @default(true) @map("is_balance_tracked")
  allowHalfDay       Boolean  @default(true) @map("allow_half_day")
  requiresDocument   Boolean  @default(false) @map("requires_document")
  maxConsecutiveDays Int?     @map("max_consecutive_days")
  color              String?
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policies LeavePolicy[]
  balances LeaveBalance[]
  requests LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("leave_types")
}

model LeavePolicy {
  id                       String             @id @default(uuid())
  tenantId                 String             @map("tenant_id")
  leaveTypeId              String             @map("leave_type_id")
  designationLevel         Int?               @map("designation_level")
  entitledDaysPerYear      Decimal            @map("entitled_days_per_year")
  accrualMethod            String @default("ANNUAL_LUMP") @map("accrual_method")
  carryForwardMax          Decimal?           @map("carry_forward_max")
  carryForwardExpiryMonths Int?               @map("carry_forward_expiry_months")
  minTenureMonths          Int                @default(0) @map("min_tenure_months")
  isActive                 Boolean            @default(true) @map("is_active")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([tenantId, leaveTypeId])
  @@map("leave_policies")
}

model LeaveBalance {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  employeeId   String   @map("employee_id")
  leaveTypeId  String   @map("leave_type_id")
  cycleYear    Int      @map("cycle_year")
  entitledDays Decimal  @default(0) @map("entitled_days")
  usedDays     Decimal  @default(0) @map("used_days")
  pendingDays  Decimal  @default(0) @map("pending_days")
  carriedDays  Decimal  @default(0) @map("carried_days")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([tenantId, employeeId, leaveTypeId, cycleYear])
  @@index([tenantId, employeeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id                String             @id @default(uuid())
  tenantId          String             @map("tenant_id")
  employeeId        String             @map("employee_id")
  leaveTypeId       String             @map("leave_type_id")
  startDate         DateTime           @map("start_date")
  endDate           DateTime           @map("end_date")
  isHalfDay         Boolean            @default(false) @map("is_half_day")
  totalDays         Decimal            @map("total_days")
  balanceImpactDays Decimal            @map("balance_impact_days")
  reason            String?
  documentUrl       String?            @map("document_url")
  status            String @default("PENDING")
  approverId        String?            @map("approver_id")
  decidedAt         DateTime?          @map("decided_at")
  decisionNotes     String?            @map("decision_notes")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, startDate, endDate])
  @@map("leave_requests")
}

model Holiday {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  storeId     String?     @map("store_id")
  name        String
  date        DateTime
  type        String @default("PUBLIC")
  isRecurring Boolean     @default(false) @map("is_recurring")
  countryCode String?     @map("country_code")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, storeId, date, name])
  @@index([tenantId, date])
  @@map("holidays")
}

// ============================================================================
// HRM — PAYROLL (Phase 10, deep-dives/5.hrm-payroll.md)
// ============================================================================
//
// Salary structures & components (templates — mutable, future-effective).
// EmployeeSalary (effective-dated assignment).
// PayrollRun (batch workflow — mutable until terminal).
// Payslip + PayslipLine (IMMUTABLE once FINALIZED — locked #14).
// SalaryAdvance (loan/advance workflow + recovery).
//
// Money:; percentages:; OT hours:.
// No updatedAt on Payslip / PayslipLine — they are immutable legal records.
//

model SalaryStructure {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  countryCode String?  @map("country_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  components SalaryComponent[]
  salaries   EmployeeSalary[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("salary_structures")
}

model SalaryComponent {
  id                String              @id @default(uuid())
  tenantId          String              @map("tenant_id")
  salaryStructureId String              @map("salary_structure_id")
  name              String
  code              String
  type              String
  calcMethod        String @map("calc_method")
  fixedAmount       Decimal?            @map("fixed_amount")
  percentValue      Decimal?            @map("percent_value")
  formulaKey        String?             @map("formula_key")
  isTaxable         Boolean             @default(true) @map("is_taxable")
  displayOrder      Int                 @default(0) @map("display_order")
  isActive          Boolean             @default(true) @map("is_active")

  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, salaryStructureId, code])
  @@index([tenantId, salaryStructureId])
  @@map("salary_components")
}

model EmployeeSalary {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  employeeId        String    @map("employee_id")
  salaryStructureId String    @map("salary_structure_id")
  basicPay          Decimal   @map("basic_pay")
  ctc               Decimal?
  currency          String
  effectiveFrom     DateTime  @map("effective_from")
  effectiveTo       DateTime? @map("effective_to")
  supersededById    String?   @map("superseded_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  employee        Employee        @relation(fields: [employeeId], references: [id])
  salaryStructure SalaryStructure @relation(fields: [salaryStructureId], references: [id])
  payslips        Payslip[]

  @@index([tenantId, employeeId, effectiveFrom])
  @@map("employee_salaries")
}

model PayrollRun {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  name            String
  periodStart     DateTime         @map("period_start")
  periodEnd       DateTime         @map("period_end")
  payCycle        String         @default("MONTHLY") @map("pay_cycle")
  storeId         String?          @map("store_id")
  status          String @default("DRAFT")
  totalGross      Decimal?         @map("total_gross")
  totalNet        Decimal?         @map("total_net")
  totalDeductions Decimal?         @map("total_deductions")
  employeeCount   Int?             @map("employee_count")
  processedById   String?          @map("processed_by_id")
  approvedById    String?          @map("approved_by_id")
  disbursedById   String?          @map("disbursed_by_id")
  processedAt     DateTime?        @map("processed_at")
  approvedAt      DateTime?        @map("approved_at")
  disbursedAt     DateTime?        @map("disbursed_at")
  failureReason   String?          @map("failure_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@index([tenantId, status])
  @@index([tenantId, periodStart, periodEnd])
  @@map("payroll_runs")
}

model Payslip {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  payrollRunId      String        @map("payroll_run_id")
  employeeId        String        @map("employee_id")
  employeeSalaryId  String        @map("employee_salary_id")
  periodStart       DateTime      @map("period_start")
  periodEnd         DateTime      @map("period_end")
  currency          String
  grossPay          Decimal       @map("gross_pay")
  totalDeductions   Decimal       @map("total_deductions")
  netPay            Decimal       @map("net_pay")
  daysWorked        Decimal       @map("days_worked")
  daysAbsent        Decimal       @map("days_absent")
  overtimeHours     Decimal       @default(0) @map("overtime_hours")
  status            String @default("DRAFT")
  flags             Json          @default("[]")
  finalizedAt       DateTime?     @map("finalized_at")
  reversesPayslipId String?       @map("reverses_payslip_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  // NO updatedAt — immutable legal record once FINALIZED (locked #14)

  payrollRun     PayrollRun     @relation(fields: [payrollRunId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])
  employeeSalary EmployeeSalary @relation(fields: [employeeSalaryId], references: [id])
  lines          PayslipLine[]

  @@unique([tenantId, payrollRunId, employeeId])
  @@index([tenantId, employeeId])
  @@map("payslips")
}

model PayslipLine {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  payslipId     String              @map("payslip_id")
  componentCode String              @map("component_code")
  label         String
  type          String
  amount        Decimal
  isTaxable     Boolean             @default(true) @map("is_taxable")
  displayOrder  Int                 @default(0) @map("display_order")
  meta          Json?
  // NO updatedAt — immutable

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([tenantId, payslipId])
  @@map("payslip_lines")
}

model SalaryAdvance {
  id                   String              @id @default(uuid())
  tenantId             String              @map("tenant_id")
  employeeId           String              @map("employee_id")
  amount               Decimal
  currency             String
  reason               String?
  installments         Int                 @default(1)
  amountPerInstallment Decimal             @map("amount_per_installment")
  recoveredAmount      Decimal             @default(0) @map("recovered_amount")
  status               String @default("PENDING")
  approvedById         String?             @map("approved_by_id")
  disbursedAt          DateTime?           @map("disbursed_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("salary_advances")
}

