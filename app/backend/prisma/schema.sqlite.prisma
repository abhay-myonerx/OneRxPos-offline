// RECEIPT TEMPLATE (customizable per tenant)
// ============================================================================

model ReceiptTemplate {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")
  name     String @default("Default")

  // ── Branding ──
  logoUrl         String? @map("logo_url")
  businessName    String? @map("business_name")
  businessAddress String? @map("business_address")
  businessPhone   String? @map("business_phone")
  businessEmail   String? @map("business_email")
  taxId           String? @map("tax_id")
  website         String?

  // ── Layout & content ──
  headerText  String? @map("header_text")
  footerText  String? @map("footer_text")
  termsText   String? @map("terms_text")
  thankYouMsg String? @default("Thank you for your purchase!") @map("thank_you_msg")

  // ── Display options (JSON) ──
  // showLogo, showBarcode, showQrCode, showTaxBreakdown, showCashierName,
  // showCustomerInfo, showPaymentDetails, showStoreName, showStoreAddress,
  // paperSize (58mm | 80mm | A4), fontSize (small | medium | large)
  displayOptions Json @default("{}") @map("display_options")

  // ── Custom fields (JSON array of {label, value} pairs) ──
  customFields Json @default("[]") @map("custom_fields")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("receipt_templates")
}

