  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

// ============================================================================
// NOTIFICATIONS (in-app real-time)
// ============================================================================
//
// One row PER RECIPIENT — the fan-out (role/store/tenant → individual users)
// is resolved at creation time so each user owns their own read state and an
// O(1) unread count. Real-time delivery is decoupled from persistence: the
// notification service writes these rows, then publishes to a Redis pub/sub
// channel that every API instance subscribes to and re-emits over Socket.IO
// (so notifications raised inside the standalone BullMQ worker — which has no
// Socket.IO server of its own — still reach connected clients).

model Notification {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String           @map("user_id")
  type      String @default("SYSTEM")
  title     String
  body      String
  // Optional in-app deep link (relative path, e.g. "/inventory/products/123").
  link      String?
  // Arbitrary structured payload (entity ids, counts) for the client.
  data      Json             @default("{}")
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Primary access pattern: a user's inbox ordered newest-first, with an
  // unread filter. The composite index serves both the list and the count.
  @@index([tenantId, userId, isRead, createdAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

// 3H.1 durable outbound-message outbox + deliverability audit trail. One row per
// outbound email: persisted BEFORE any send attempt (so a crash/offline window
// never loses a receipt/statement), drained by a Redis-free background worker.
model MessageLog {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  storeId           String?              @map("store_id")
  channel           String       @default("EMAIL")
  transport         String
  kind              String
  toAddress         String               @map("to_address")
  toName            String?              @map("to_name")
  subject           String
  bodyHtml          String               @map("body_html")
  bodyText          String?              @map("body_text")
  relatedType       String?              @map("related_type")
  relatedId         String?              @map("related_id")
  status            String        @default("QUEUED")
  attempts          Int                  @default(0)
  maxAttempts       Int                  @default(5) @map("max_attempts")
  lastError         String?              @map("last_error")
  providerMessageId String?              @map("provider_message_id")
  createdBy         String?              @map("created_by")
  queuedAt          DateTime             @default(now()) @map("queued_at")
  nextAttemptAt     DateTime?            @map("next_attempt_at")
  sentAt            DateTime?            @map("sent_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Drain query: due rows for a tenant by status + schedule.
  @@index([tenantId, status, nextAttemptAt])
  // Audit listing: newest-first per kind.
  @@index([tenantId, kind, queuedAt])
  // "Was this receipt/PO already emailed?"
  @@index([relatedType, relatedId])
  @@map("message_logs")
}

// 3H.4 rules-based promotion. One type-discriminated model; type-specific params
// live in the validated `config` JSON (scope + percents/amounts/tiers/etc). The
// pure engine (rx-pos-shared) reads config; the backend validates it on write.
model Promotion {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  name            String
  type            String
  isActive        Boolean       @default(true) @map("is_active")
  priority        Int           @default(0)
  stackable       Boolean       @default(false)
  startsAt        DateTime?     @map("starts_at")
  endsAt          DateTime?     @map("ends_at")
  // Set only for COUPON promos; null = auto-apply. Unique per tenant.
  couponCode      String?       @map("coupon_code")
  customerGroupId String?       @map("customer_group_id")
  minSubtotal     Decimal?      @map("min_subtotal")
  usageLimit      Int?          @map("usage_limit")
  timesUsed       Int           @default(0) @map("times_used")
  config          Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions PromotionRedemption[]

  @@unique([tenantId, couponCode])
  @@index([tenantId, isActive])
  @@map("promotions")
}

// One row per promotion applied to a completed sale (usage tracking + reporting).
model PromotionRedemption {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  promotionId String   @map("promotion_id")
  saleId      String   @map("sale_id")
  customerId  String?  @map("customer_id")
  amount      Decimal
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  sale      Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId, promotionId])
  @@index([saleId])
  @@map("promotion_redemptions")
}

