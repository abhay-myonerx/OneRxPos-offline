  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  stores               Store[]
  users                User[]
  products             Product[]
  categories           Category[]
  brands               Brand[]
  customers            Customer[]
  customerGroups       CustomerGroup[]
  suppliers            Supplier[]
