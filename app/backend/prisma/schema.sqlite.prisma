model Store {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  name              String
  code              String
  address           String?
  phone             String?
  email             String?
  province          String? @map("province")
  isActive          Boolean       @default(true) @map("is_active")
  settings          Json          @default("{}")
  // ── Phase 21a / OI-030 — Attendance geo + IP enforcement ─────
  // Operational columns hit on every punch — promoted to real
  // columns (vs Tenant.settings JSON) to keep the validator
  // O(1) without parsing JSON on the hot path.
  geoLat            Decimal?      @map("geo_lat")
  geoLng            Decimal?      @map("geo_lng")
  geoRadiusM        Int?          @map("geo_radius_m")
  // Postgres text array of CIDRs (e.g. "203.0.113.0/24"). Empty
  // array means "no IP restriction". String array (not String[]
  // mapped) because Prisma's native String[] uses TEXT[] which
  // matches our needs.
  ipWhitelist       Json      @default("[]") @map("ip_whitelist")
  // Methods this store accepts for attendance. Empty array means
  // "accept any" (back-compat with stores that don't care). Values
  // are AttendanceMethod enum strings: WEB, MANUAL, GEOFENCE,
  // IP_RESTRICTED, QR_CODE, BIOMETRIC.
  attendanceMethods Json      @default("[]") @map("attendance_methods")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          User[]
  storeStock     StoreStock[]
  sales          Sale[]
  stockMovements StockMovement[]
  purchases      PurchaseOrder[]
  expenses       Expense[]
  cashierShifts  CashierShift[]
  transfersFrom  StockTransfer[] @relation("TransferFrom")
  transfersTo    StockTransfer[] @relation("TransferTo")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("stores")
}

