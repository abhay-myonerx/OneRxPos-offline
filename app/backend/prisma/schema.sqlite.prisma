// ============================================================================
// LICENSING (Phase 0.5) — cloud-side license binding
// ============================================================================

model License {
  id          String             @id @default(uuid())
  tenantId    String             @map("tenant_id")
  key         String             @unique
  plan        String             @default("standard")
  seatCap     Int                @default(1) @map("seat_cap")
  status      String             @default("active") // active | suspended | revoked
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  activations DeviceActivation[]

  @@index([tenantId])
  @@map("licenses")
}

model DeviceActivation {
  id                String    @id @default(uuid())
  licenseId         String    @map("license_id")
  license           License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  deviceFingerprint String    @map("device_fingerprint")
  storeId           String?   @map("store_id")
  activatedAt       DateTime  @default(now()) @map("activated_at")
  lastValidatedAt   DateTime  @default(now()) @map("last_validated_at")
  revokedAt         DateTime? @map("revoked_at")

  @@unique([licenseId, deviceFingerprint])
  @@index([licenseId])
  @@map("device_activations")
}

// ============================================================================
// POS AUTH — device enrollment & PIN login (Phase 1.1)
// ============================================================================
//
// EnrolledDevice/UserPin/PinLockout are auth infrastructure queried directly
// by the pos-auth services (not through the per-tenant `createTenantClient`
// request client the way business tables are). UserPin/PinLockout are keyed
// by userId/fingerprint rather than tenantId, so they carry no tenant column
// at all. EnrolledDevice does carry tenantId — see tenant-scope.test.ts
// SCOPING_EXCEPTIONS for why it's intentionally excluded from
// DIRECT_TENANT_MODELS.

model EnrolledDevice {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  storeId          String    @map("store_id")
  fingerprint      String
  name             String?
  enrolledByUserId String    @map("enrolled_by_user_id")
  enrolledAt       DateTime  @default(now()) @map("enrolled_at")
  revokedAt        DateTime? @map("revoked_at")

  @@unique([tenantId, fingerprint])
  @@index([tenantId, storeId])
  @@map("enrolled_devices")
}

model UserPin {
  userId    String   @id @map("user_id")
  pinHash   String   @map("pin_hash")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_pins")
}

model PinLockout {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  fingerprint String
  attempts    Int       @default(0)
  lockedUntil DateTime? @map("locked_until")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, fingerprint])
  @@map("pin_lockouts")
}

// ============================================================================
// SYNC OUTBOX (Store-Node SN-3) — trigger-captured write queue
// ============================================================================
//
// Exists in BOTH the Postgres and sqlite schemas, but is only ever WRITTEN TO
// on the store-node (sqlite) backend: `scripts/generate-sync-triggers.ts`
// generates `AFTER INSERT/UPDATE/DELETE` triggers on every syncable tenant
// table that insert a row here, and `src/local/sqlite-push.ts` installs those
// triggers on the encrypted SQLite file at push time — never on Postgres.
// SQLite trigger execution is part of the same transaction as the write it
// captures, so a rolled-back domain write rolls its outbox row back too
// (spike-verified, SN-3 Task 0). The best-effort drainer (SN-3 Task 2) reads
// `status = "pending"` rows ordered by `nextAttemptAt`, encrypts the current
// row's data at drain time, and POSTs it to the cloud `/sync` endpoint.
model SyncOutbox {
  id            String    @id @default(uuid())
  entity        String
  entityId      String    @map("entity_id")
  op            String
  status        String    @default("pending")
  attempts      Int       @default(0)
  nextAttemptAt DateTime? @map("next_attempt_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([status, nextAttemptAt])
  @@map("sync_outbox")
}
