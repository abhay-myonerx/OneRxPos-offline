// Rx-at-till link (Phase 2.2). Ties a prescription-only sale line to a
// prescription NUMBER + copay, PII-FREE by design: NO patient or prescriber
// columns are stored. Enforced at checkout by the pharmacy compliance hook (a
// NEEDS_RX / NARCOTIC line must carry one of these); persisted inside the sale's
// own $transaction. `consultAck` records that a behind-counter pharmacist
// consult was authorized for the line.
model RxLink {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  saleId     String   @map("sale_id")
  saleItemId String?  @map("sale_item_id")
  productId  String   @map("product_id")
  din        String?
  rxNumber   String   @map("rx_number")
  copay      Decimal?
  consultAck Boolean  @default(false) @map("consult_ack")
  createdAt  DateTime @default(now()) @map("created_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId, rxNumber])
  @@index([saleId])
  @@map("rx_links")
}

// Controlled-substances / narcotic log (Phase 2.4). A perpetual narcotic count
// with reconciliation, PII-FREE by design: the only person referenced is a staff
// witness (`witness_user_id`) and the recorder (`created_by_user_id`) — NO patient
// or prescriber columns. Tenant-scoped (has `tenant_id`), added to
// DIRECT_TENANT_MODELS. Deliberately relationless (no FKs): the log is decoupled
// audit data derived alongside the StockMovement ledger.
//   • COUNT: observation-only — snapshots `expected_qty` (on-hand), stores
//     `counted_qty`, `discrepancy = counted − expected`. Does NOT move stock.
//   • LOSS/THEFT/DESTRUCTION: stores `quantity_change` (negative) + reason +
//     witness, posted alongside an `ADJUSTMENT_SUB` StockMovement in one txn.
model NarcoticEvent {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  storeId         String   @map("store_id")
  productId       String   @map("product_id")
  shiftId         String?  @map("shift_id")
  eventType       String   @map("event_type") // COUNT | LOSS | THEFT | DESTRUCTION
  expectedQty     Int      @map("expected_qty")
  countedQty      Int?     @map("counted_qty")
  quantityChange  Int?     @map("quantity_change")
  discrepancy     Int?
  reason          String?
  witnessUserId   String?  @map("witness_user_id")
  createdByUserId String   @map("created_by_user_id")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId, productId, createdAt])
  @@map("narcotic_events")
}

